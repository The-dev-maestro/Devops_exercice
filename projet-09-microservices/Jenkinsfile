pipeline{
    agent any
    tools {
        nodejs "node20"
    }
    environment {
        DOCKERHUB_CREDENTIALS = credentials('084d1a9f-d13f-4311-be4b-f5ecd995c3b3')
        REGISTRY = 'warren042'
        EC2_HOST = 'ec2-13-48-27-172.eu-north-1.compute.amazonaws.com'
    }
    stages{
        stage('Build all services') {
            parallel {
                stage('Build Gateway') {
                    steps {
                        dir('projet-09-microservices') {
                            sh 'docker build --no-cache -t ${REGISTRY}/gateway:${BUILD_NUMBER} ./api-gateway'
                        }
                    }
                }
                stage('Build User Service') {
                    steps {
                        dir('projet-09-microservices') {
                            sh 'docker build --no-cache -t ${REGISTRY}/user-service:${BUILD_NUMBER} ./user-service'
                        }
                    }
                }
                stage('Build Product Service') {
                    steps {
                        dir('projet-09-microservices') {
                            sh 'docker build --no-cache -t ${REGISTRY}/product-service:${BUILD_NUMBER} ./product-service'
                        }
                    }
                }
            }
        }
        stage('Integration Test - Debug'){
    steps{
        dir('projet-09-microservices'){
            sh '''
            docker-compose up -d
            sleep 10
            
            echo "=== Container Status ==="
            docker-compose ps
            
            echo "=== Gateway Logs ==="
            docker-compose logs gateway
            
            echo "=== Port Mapping Check ==="
            docker port projet-09-microservices-gateway-1
            
            echo "=== Testing Connection ==="
            curl -v  curl -f http://gateway:5001/health || echo "Connection failed"
            '''
        }
    }
}
stage('Integration Test') {
    steps {
        dir('projet-09-microservices') {
            sh '''
                docker-compose up -d
                sleep 5
                curl -f http://gateway:5001/health
                curl -f http://user-service:3000/users
                curl -f http://product-service:3000/products
            '''
        }
    }
}

        stage('Push All to dockerhub'){
           steps{
            sh'''
            echo $DOCKERHUB_CREDENTIALS_PSW | docker login -u $DOCKERHUB_CREDENTIALS_USR --password-stdin
            docker push ${REGISTRY}/gateway:${BUILD_NUMBER}
            docker push ${REGISTRY}/product-service:${BUILD_NUMBER}
            docker push ${REGISTRY}/user-service:${BUILD_NUMBER}
            '''
           }
        }
        stage('Deploy to AWS'){
            steps{
                sshagent(credentials:['aws-ec2-ssh-key']){
                    sh"""
                    ssh -o StrictHostKeyChecking=no ec2-user@${EC2_HOST} 'mkdir -p ~/projet09'
                    scp -o StrictHostKeyChecking=no projet-09-microservices/docker-compose.yml ec2-user@${EC2_HOST}:~/projet09/docker-compose.yml
                    ssh -o StrictHostKeyChecking=no ec2-user@${EC2_HOST} <<'ENDSSH'
                    cd ~/projet09
                    export REGISTRY=${REGISTRY}
                    export TAG=${BUILD_NUMBER}
                    docker-compose pull
                    docker-compose up -d
                    sleep 5
                    curl http://localhost:8081/health
ENDSSH
                    """
                }
            }
        }
    }
    post{
    always{
        dir('projet-09-microservices'){
            sh 'docker-compose down || true'
        }
        sh 'docker logout || true'
    }
    failure{
        echo 'Pipeline failed - check integration tests'
    }
}
}