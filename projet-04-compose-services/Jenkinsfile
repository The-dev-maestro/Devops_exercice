pipeline {
    agent any

    stages {
        stage('Build avec Compose') {
            steps {
                dir('projet-04-compose-services') {
                    sh 'docker-compose build'
                }
            }
        }

        stage('Démarrer les services') {
            steps {
                dir('projet-04-compose-services') {
                    sh 'docker-compose up -d'
                    sh 'sleep 5'
                }
            }
        }

        stage('Tests d\'intégration') {
            steps {
                dir('projet-04-compose-services') {
                    sh '''
                        docker network connect projet-04-compose-services_default jenkins || true
                        curl -f http://projet-04-compose-services-app-1:3000/health || exit 1
                        echo "Health check OK"
                        curl -f http://projet-04-compose-services-app-1:3000/ || exit 1
                        RESPONSE=$(curl -s http://projet-04-compose-services-app-1:3000/)
                        echo "Response: $RESPONSE"
                    '''
                }
            }
        }
    }

    post {
        always {
            dir('projet-04-compose-services') {
                sh 'docker network disconnect projet-04-compose-services_default jenkins || true'
                sh 'docker-compose down --volumes'
            }
        }
    }
}