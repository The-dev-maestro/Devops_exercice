pipeline{
    agent any
    tools{
        nodejs 'node20'
    }
    triggers {
    gitlab(triggerOnPush: true)
}
   

    stages{
        stage('Install'){
            steps{
                dir('projet-02-node-test'){
                    sh 'npm ci'
                }
            }
        }
        stage('Test'){
            steps{
                dir('projet-02-node-test'){
                    echo 'Executions des testes...'
                    sh 'npm test'
                }
            }
        }
        stage('Build'){
            steps{
                echo '===== Build de docker image ====='
                dir('projet-02-node-test'){
                     sh 'docker build -t project02:${BUILD_NUMBER} .'
                }  
            }
        }
        stage('verify container'){
            steps{
                sh '''
                docker run -d --name test-project02 --network devops-exercices_default project02:${BUILD_NUMBER}
                sleep 5
                curl -f http://test-project02:3000/health || exit 1
                docker stop test-project02
                docker rm test-project02
                '''
            }
        }
    }
    post {
        failure {
            echo 'Pipeline ECHOUE - vérifier les logs'
        }
        always {
           sh 'docker rm -f test-project02 || true'
        }
    }
}